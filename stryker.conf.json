{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "mutator": {
    "name": "typescript",
    "excludedMutations": [
      "stringLiteral"
    ]
  },
  "packageManager": "npm",
  "reporters": ["html", "clear-text"],
  "testRunner": "vitest",
  "vitestConfigFile": "vitest.config.ts",
  "tsconfigFile": "tsconfig.json",
  "files": [
    "src/**/*.ts"
  ],
  "thresholds": {
    "high": 80,
    "low": 70,
    "break": 50
  }
}

