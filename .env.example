# Required API key for OpenRouter
# Get your free key at: https://openrouter.ai/
OPENROUTER_API_KEY=your_api_key_here

# Optional: Ollama base URL (defaults to http://localhost:11434)
# Only needed if using -p ollama flag
# OLLAMA_BASE_URL=http://localhost:11434

# Optional: Ollama API key (only if your Ollama instance requires authentication)
# OLLAMA_API_KEY=your_ollama_api_key
